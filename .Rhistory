st_drop_geometry() %>%
# take log of sale price to address right-skew
mutate(log_sale_price = log(sale_price + 1)) %>%
# Keep only the variables we'll actually use
select(
opa_number,
year,
delinquent,         # outcome
# Lag variables
lag_delinquent,
times_delinquent_before,
# Property characteristics
total_livable_area,
log_sale_price,
year_built,
# Census block-group/tract level
MEDHHINCE,
OWNER_RATE,
OVER65_PROP,
VACANCY_RATE,
POV_RATE,
SNAP_RATE,
# Spatial features (best 3)
in_bid,
dist_HCA,
in_emp
) %>%
na.omit()
# Quick sanity check
cat("Rows:", nrow(model_df), "\n")
cat("Delinquency rate:", round(mean(model_df$delinquent), 3), "\n")
cat("Years in data:", paste(sort(unique(model_df$year)), collapse = ", "), "\n")
